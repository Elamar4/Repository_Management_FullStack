@{
    Layout = null;
    ViewData["Title"] = "Yeni qaimə";
}
<!DOCTYPE html>
<html lang="az">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Kapital A.S. MMC - Yeni qaimə</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/assets/css/new-invoice.css" />
</head>
<body>
    <div class="page-shell">
        <div class="page">
            <main class="invoice-layout">
                <section class="left-panel">
                    <div class="panel-card info-card">
                        <div class="panel-title">Qaimə haqqında məlumat</div>
                        <div class="form-grid-2">
                            <div class="form-group">
                                <label for="invoiceDate">Tarix</label>
                                <input type="date" id="invoiceDate" />
                            </div>
                            <div class="form-group">
                                <label for="invoiceNo">Nömrə</label>
                                <input type="text" id="invoiceNo" placeholder="Məs: QM-240001" />
                            </div>
                            <div class="form-group full">
                                <label for="selectedCustomerName">Müştəri</label>
                                <div class="inline-actions customer-actions">
                                    <input type="text" id="selectedCustomerName" readonly placeholder="Müştəri seçilməyib" />
                                    <button type="button" id="openCustomerPickerBtn" class="secondary-btn">Müştəri seç</button>
                                    <button type="button" id="openAddCustomerBtn" class="secondary-btn">+ Müştəri əlavə et</button>
                                </div>
                            </div>
                            <div class="form-group">
                                <label for="customerPhone">Telefon</label>
                                <input type="text" id="customerPhone" readonly />
                            </div>
                            <div class="form-group">
                                <label for="customerExtraPhone">Əlavə telefon</label>
                                <input type="text" id="customerExtraPhone" placeholder="Əlavə nömrə (bu qaimə üçün dəyişilə bilər)" />
                            </div>
                            <div class="form-group">
                                <label for="customerAddress">Ünvan</label>
                                <input type="text" id="customerAddress" readonly />
                            </div>
                            <div class="form-group full">
                                <label for="invoiceNote">Qeyd</label>
                                <textarea id="invoiceNote" rows="3" placeholder="Əlavə qeyd"></textarea>
                            </div>
                            <div class="form-group full">
                                <label for="returnDate">Ümumi təhvil tarixi</label>
                                <input type="date" id="returnDate" />
                            </div>
                        </div>
                    </div>

                    <div class="panel-card add-item-card">
                        <div class="panel-title">Əlavə ediləcək mal / xidmət</div>
                        <div class="add-item-body">
                            <div class="form-group">
                                <label for="itemCategory">Kateqoriya</label>
                                <select id="itemCategory"></select>
                            </div>

                            <div id="normalItemFields" class="hidden">
                                <div class="form-grid-2">
                                    <div class="form-group full">
                                        <label for="itemVariant">Seçim</label>
                                        <select id="itemVariant"></select>
                                    </div>
                                    <div class="form-group">
                                        <label for="itemQuantity">Miqdar</label>
                                        <input type="number" id="itemQuantity" min="1" step="1" value="1" />
                                    </div>
                                    <div class="form-group">
                                        <label for="itemPrice">Qiymət</label>
                                        <input type="number" id="itemPrice" min="0" step="0.01" />
                                    </div>
                                    <div class="form-group full">
                                        <label for="itemNote">Qeyd</label>
                                        <input type="text" id="itemNote" placeholder="İstəyə bağlı qeyd" />
                                    </div>
                                </div>
                            </div>

                            <div id="taxtaFields" class="hidden">
                                <div class="form-grid-2">
                                    <div class="form-group">
                                        <label for="taxtaType">Növ</label>
                                        <select id="taxtaType">
                                            <option value="">Seç</option>
                                            <option value="5/10">5/10</option>
                                            <option value="5/15">5/15</option>
                                        </select>
                                    </div>
                                    <div class="form-group">
                                        <label for="taxtaLength">Uzunluq (m)</label>
                                        <input type="number" id="taxtaLength" min="0.01" step="0.01" />
                                    </div>
                                    <div class="form-group">
                                        <label for="taxtaRate">1 metr qiyməti</label>
                                        <input type="number" id="taxtaRate" min="0" step="0.01" value="0.60" />
                                    </div>
                                    <div class="form-group">
                                        <label for="taxtaQuantity">Miqdar</label>
                                        <input type="number" id="taxtaQuantity" min="1" step="1" value="1" />
                                    </div>
                                    <div class="form-group full">
                                        <label for="taxtaPrice">Cəmi qiymət</label>
                                        <input type="number" id="taxtaPrice" min="0" step="0.01" />
                                    </div>
                                </div>
                            </div>

                            <div id="sheetItemFields" class="hidden">
                                <div class="form-grid-2">
                                    <div class="form-group">
                                        <label for="sheetSideA">1-ci tərəf (m)</label>
                                        <input type="number" id="sheetSideA" min="0.01" step="0.01" />
                                    </div>
                                    <div class="form-group">
                                        <label for="sheetSideB">2-ci tərəf (m)</label>
                                        <input type="number" id="sheetSideB" min="0.01" step="0.01" />
                                    </div>
                                    <div class="form-group">
                                        <label for="sheetArea">Kvadrat (m²)</label>
                                        <input type="number" id="sheetArea" readonly />
                                    </div>
                                    <div class="form-group">
                                        <label for="sheetRate">1 m² qiyməti</label>
                                        <input type="number" id="sheetRate" min="0" step="0.01" />
                                    </div>
                                    <div class="form-group">
                                        <label for="sheetQuantity">Miqdar</label>
                                        <input type="number" id="sheetQuantity" min="1" step="1" value="1" />
                                    </div>
                                    <div class="form-group">
                                        <label for="sheetPrice">Cəmi qiymət</label>
                                        <input type="number" id="sheetPrice" min="0" step="0.01" />
                                    </div>
                                </div>
                            </div>

                            <div id="lesaFields" class="hidden">
                                <div class="form-grid-2 lesa-grid">
                                    <div class="form-group">
                                        <label for="lesaHeadCount">Başlıq sayı</label>
                                        <input type="number" id="lesaHeadCount" min="0" step="1" value="1" />
                                    </div>
                                    <div class="form-group">
                                        <label for="lesaHeadPrice">Başlıq qiyməti</label>
                                        <input type="number" id="lesaHeadPrice" min="0" step="0.01" value="5" />
                                    </div>
                                    <div class="form-group">
                                        <label for="lesaLongRodCount">Uzun çubuq sayı</label>
                                        <input type="number" id="lesaLongRodCount" min="0" step="1" value="0" />
                                    </div>
                                    <div class="form-group">
                                        <label for="lesaShortRodCount">Balaca çubuq sayı</label>
                                        <input type="number" id="lesaShortRodCount" min="0" step="1" value="0" />
                                    </div>
                                    <div class="form-group">
                                        <label for="lesaFreeTaxtaCount">Taxta 5/15 3.00 sayı</label>
                                        <input type="number" id="lesaFreeTaxtaCount" min="0" step="1" value="0" />
                                    </div>
                                    <div class="form-group">
                                        <label for="lesaExtraTaxtaCount">Əlavə taxta 5/15 3.00 sayı</label>
                                        <input type="number" id="lesaExtraTaxtaCount" min="0" step="1" value="0" />
                                    </div>
                                    <div class="form-group full">
                                        <label for="lesaExtraTaxtaPrice">Taxta 5/15 qiyməti</label>
                                        <input type="number" id="lesaExtraTaxtaPrice" min="0" step="0.01" value="3" />
                                    </div>
                                </div>
                            </div>

                            <div id="tekerliLesaFields" class="hidden">
                                <div class="form-grid-2">
                                    <div class="form-group">
                                        <label for="tekerliHeadCount">Başlıq sayı</label>
                                        <input type="number" id="tekerliHeadCount" min="0" step="1" value="1" />
                                    </div>
                                    <div class="form-group">
                                        <label for="tekerliRodCount">Çubuq sayı</label>
                                        <input type="number" id="tekerliRodCount" min="0" step="1" value="0" />
                                    </div>
                                    <div class="form-group">
                                        <label for="tekerliVilkaCount">Vilka sayı</label>
                                        <input type="number" id="tekerliVilkaCount" min="0" step="1" value="0" />
                                    </div>
                                    <div class="form-group">
                                        <label for="tekerliBoardCount">Təkərli lesanın taxtası sayı</label>
                                        <input type="number" id="tekerliBoardCount" min="0" step="1" value="0" />
                                    </div>
                                    <div class="form-group">
                                        <label for="tekerliExtraBoardCount">Əlavə taxta sayı</label>
                                        <input type="number" id="tekerliExtraBoardCount" min="0" step="1" value="0" />
                                    </div>
                                    <div class="form-group">
                                        <label for="tekerliExtraBoardPrice">Əlavə taxta qiyməti</label>
                                        <input type="number" id="tekerliExtraBoardPrice" min="0" step="0.01" value="2" />
                                    </div>
                                    <div class="form-group">
                                        <label for="tekerliDayCount">Gün sayı</label>
                                        <input type="number" id="tekerliDayCount" min="1" step="1" value="1" />
                                    </div>
                                    <div class="form-group">
                                        <label for="tekerliDailyPrice">Günlük qiymət</label>
                                        <input type="number" id="tekerliDailyPrice" min="0" step="0.01" value="20" />
                                    </div>
                                </div>
                            </div>

                            <div id="demirDirekFields" class="hidden">
                                <div class="form-grid-2">
                                    <div class="form-group full"><label for="demirDirekCategorySelect">Dirəyin ölçüsü / kateqoriyası</label><select id="demirDirekCategorySelect"></select></div>
                                    <div class="form-group"><label for="demirDirekQuantity">Dirək sayı</label><input type="number" id="demirDirekQuantity" min="1" step="1" value="1" /></div>
                                    <div class="form-group"><label for="demirDirekPrice">1 ədəd qiyməti</label><input type="number" id="demirDirekPrice" min="0" step="0.01" value="0" readonly /></div>
                                    <div class="form-group"><label for="demirDirekPalesCount">Pales sayı</label><input type="number" id="demirDirekPalesCount" min="0" step="1" value="0" /></div>
                                    <div class="form-group full"><label for="demirDirekNote">Qeyd</label><input type="text" id="demirDirekNote" placeholder="İstəyə bağlı qeyd" /></div>
                                </div>
                            </div>

                            <div id="transportFields" class="hidden">
                                <div class="form-grid-2">
                                    <div class="form-group full">
                                        <label for="transportType">Nəqliyyat növü</label>
                                        <select id="transportType">
                                            <option value="">Seç</option>
                                            <option value="gedis">Gediş</option>
                                            <option value="gelis">Gəliş</option>
                                            <option value="ikisibirde">İkisi bir yerdə</option>
                                        </select>
                                    </div>
                                    <div class="form-group">
                                        <label for="transportPrice">Qiymət</label>
                                        <input type="number" id="transportPrice" min="0" step="0.01" value="0" />
                                    </div>
                                    <div class="form-group">
                                        <label for="transportNote">Qeyd</label>
                                        <input type="text" id="transportNote" placeholder="Marşrut və ya qeyd" />
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="add-item-footer">
                            <button id="addItemBtn" class="primary-btn full-btn">Əlavə et</button>
                        </div>
                    </div>
                </section>

                <section class="right-panel">
                    <header class="panel-card topbar-right-card">
                        <div class="header-brand-wrap">
                            <img src="~/assets/img/kapital-logo.png" alt="Kapital A.S. MMC" class="topbar-brand-image" />
                            <div class="header-title">
                                <h1 id="pageHeading">Yeni qaimə</h1>
                                <p id="pageSubHeading">Materialın icarəyə verilməsi</p>
                            </div>
                        </div>
                        <div class="topbar-actions">
                            <a asp-controller="Home" asp-action="Index" class="secondary-btn">← Dashboard</a>
                            <button id="saveInvoiceBtnTop" class="primary-btn">Yadda saxla</button>
                        </div>
                    </header>

                    <div class="panel-card table-card">
                        <div class="panel-title">Əlavə edilən mallar</div>
                        <div class="table-wrap">
                            <table>
                                <thead>
                                    <tr>
                                        <th>Kateqoriya</th>
                                        <th>Ölçü / Təsvir</th>
                                        <th>Miqdar</th>
                                        <th>Vahid</th>
                                        <th>Qiymət</th>
                                        <th>Məbləğ</th>
                                        <th>Əməliyyat</th>
                                    </tr>
                                </thead>
                                <tbody id="itemsTableBody"></tbody>
                            </table>
                        </div>
                    </div>

                    <div class="panel-card bottom-bar">
                        <div class="money-box">
                            <label for="totalAmount">Məbləğ</label>
                            <input type="number" id="totalAmount" value="0" readonly />
                        </div>
                        <div class="money-box">
                            <label for="paidAmount">Ödənilən məbləğ</label>
                            <input type="number" id="paidAmount" value="0" min="0" step="0.01" />
                        </div>
                        <div class="money-box">
                            <label for="depositAmount">Depozit məbləği</label>
                            <input type="number" id="depositAmount" value="0" min="0" step="0.01" />
                        </div>
                        <div class="money-box">
                            <label for="remainingDebt">Son borc</label>
                            <input type="number" id="remainingDebt" value="0" readonly />
                        </div>
                    </div>
                </section>
            </main>
        </div>
    </div>

    <div class="modal-overlay hidden" id="customerPickerModal">
        <div class="customer-modal">
            <div class="customer-modal-header">
                <h3>Müştəri seç</h3>
                <button type="button" class="secondary-btn small-btn" id="closeCustomerPickerBtn">Bağla</button>
            </div>
            <div class="form-group">
                <label for="customerSearchInput">Axtarış</label>
                <input type="text" id="customerSearchInput" placeholder="Ad, telefon və ya əlavə telefonla axtar" />
            </div>
            <div class="customer-list" id="customerList"></div>
        </div>
    </div>

    <div class="modal-overlay hidden" id="addCustomerModal">
        <div class="customer-modal">
            <div class="customer-modal-header">
                <h3>Yeni müştəri əlavə et</h3>
                <button type="button" class="secondary-btn small-btn" id="closeAddCustomerBtn">Bağla</button>
            </div>
            <div class="form-grid-2">
                <div class="form-group full">
                    <label for="newCustomerName">Müştərinin adı</label>
                    <input type="text" id="newCustomerName" />
                </div>
                <div class="form-group">
                    <label for="newCustomerPhone">Telefon nömrəsi</label>
                    <input type="text" id="newCustomerPhone" />
                </div>
                <div class="form-group">
                    <label for="newCustomerExtraPhone">Əlavə telefon nömrəsi</label>
                    <input type="text" id="newCustomerExtraPhone" />
                </div>
                <div class="form-group full">
                    <label for="newCustomerAddress">Ünvan</label>
                    <input type="text" id="newCustomerAddress" />
                </div>
            </div>
            <div class="customer-modal-actions">
                <button type="button" class="primary-btn" id="saveCustomerBtn">Yadda saxla</button>
            </div>
        </div>
    </div>

    <script src="~/assets/js/api.js"></script>
    <script src="~/assets/js/seed-data.js"></script>
    <script src="~/assets/js/new-invoice.js"></script>
</body>
</html>
